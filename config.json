{
    "env_name": "Pendulum-v1",
    "obs_type": "vector",
    "obs_shape": [3],
    "action_type": "continuous",
    "seq_len": 50,
    "batch_size": 64,
    "imagine_horizon": 25,
    "latent_dim": 64,
    "hidden_dim": 256,
    "world_model_lr": 0.0003,
    "actor_lr": 0.0003,
    "critic_lr": 0.0003,
    "kl_beta": 0.1,
    "gamma": 0.99,
    "total_steps": 50000,
    "collect_episodes": 10,
    "train_world_epochs": 20,
    "train_actor_epochs": 20,
    "eval_episodes": 10,
    "obs_noise_std": 0.05,
    "action_noise_std": 0.2,
    "domain_randomization": true,
    "missing_data_prob": 0.2,
    "quantize": false,
    "prune": false,
    "export_torchscript": true,
    "save_path": "models/",
    "log_interval": 5000,
    "device": "auto",
    "industry": "manufacturing",
    "safety_threshold": 0.8,
    "compliance": ["ISO 27001", "GDPR"]
}


